# ===========================================
# 상담 신청 폼 — SMS + 이메일 발송용 환경변수
# ===========================================
# 로컬 개발 시: 이 파일을 .env.local 로 복사하고 실제 값 입력
# 프로덕션(Vercel): Vercel 대시보드 → Settings → Environment Variables 에 등록

# ──────────────── 알리고 SMS (필수) ────────────────
# aligo.in 가입 후 API 키 발급
# API 관리 → API인증 키에서 확인
ALIGO_API_KEY=
ALIGO_USER_ID=
# 발신번호 (알리고에 사전 등록한 번호, 하이픈 없이 11자리)
ALIGO_SENDER=01032623295
# 수신번호 (대표님 핸드폰, 하이픈 없이. 여러 명에게 보내려면 콤마로 구분)
# 예: 01032623295,01093744916
ALIGO_RECEIVER=01032623295
# 테스트 모드 (실제 발송 안 됨, 요금도 안 빠짐). 운영 시 false 또는 삭제
ALIGO_TEST_MODE=false

# ──────────────── Resend 이메일 (선택) ────────────────
# resend.com 가입 후 API 키 발급 (무료 월 3000건)
# 도메인 검증 없이 onboarding@resend.dev 발신 가능
RESEND_API_KEY=
# 상담 접수 알림 받을 이메일 (여러 개면 콤마 X, 한 개만 지원)
CONTACT_EMAIL_TO=cta.ryang@gmail.com
# 보내는 사람 (도메인 검증 후 자유롭게 설정 가능. 미설정 시 resend 기본값)
# CONTACT_EMAIL_FROM="세무회계 새벽 <noreply@dawntax.com>"
